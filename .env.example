# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx

# Resend (email)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=Code Hunters <noreply@codehunters.dev>

# App
NEXT_PUBLIC_APP_URL=https://www.codehunters.dev
NEXT_PUBLIC_APP_NAME=Code Hunters

# Upstash QStash — platform-independent cron scheduler
# Sign up free at https://console.upstash.com/qstash
QSTASH_TOKEN=your_qstash_token
QSTASH_CURRENT_SIGNING_KEY=your_qstash_current_signing_key
QSTASH_NEXT_SIGNING_KEY=your_qstash_next_signing_key

# Discord webhook for admin sale notifications (leave empty to disable)
DISCORD_WEBHOOK_URL=

# GST Invoice — add your GSTIN once registered at gst.gov.in (SAC 998431)
SELLER_GSTIN=
