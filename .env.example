# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx

# n8n Cloud Webhooks
N8N_WEBHOOK_BASE_URL=https://your-n8n-instance.app.n8n.cloud/webhook
N8N_ENROLLMENT_WEBHOOK=enrollment-webhook-id
N8N_STUDENT_OTP_WEBHOOK=student-otp-webhook-id
N8N_REFERRAL_REWARD_WEBHOOK=referral-reward-webhook-id
N8N_ONBOARDING_WEBHOOK=onboarding-webhook-id
N8N_COUPON_CAMPAIGN_WEBHOOK=coupon-campaign-webhook-id

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Code Hunters
