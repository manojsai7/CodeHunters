# ============================================
# Code Hunters — Environment Variables
# Copy to .env and fill in real values
# ============================================

# ── Supabase ─────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Database (Prisma) ────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/codehunters

# ── App ──────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://codehunters.dev

# ── Razorpay ─────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_xxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_xxx

# ── Resend (Email) ───────────────────────────
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=Code Hunters <noreply@codehunters.dev>

# ── Upstash QStash (Cron Jobs) ───────────────
QSTASH_TOKEN=your-qstash-token
QSTASH_CURRENT_SIGNING_KEY=your-current-signing-key
QSTASH_NEXT_SIGNING_KEY=your-next-signing-key

# ── Discord (Optional — admin sale alerts) ───
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx
